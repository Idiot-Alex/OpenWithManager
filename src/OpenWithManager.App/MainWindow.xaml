<Window x:Class="OpenWithManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenWith Manager"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#f6f4ee"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#23251f" />
        <SolidColorBrush x:Key="MutedBrush" Color="#6f6c64" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#fffefa" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#f0eee6" />
        <SolidColorBrush x:Key="LineBrush" Color="#ddd9cf" />
        <SolidColorBrush x:Key="HoverBrush" Color="#f6f3ea" />
        <SolidColorBrush x:Key="SelectedBrush" Color="#ebe7da" />

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource HoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#c9c4b8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="MinWidth" Value="38" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource InkBrush}" />
            <Setter Property="Foreground" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3a3d34" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3a3d34" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#171914" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="13,8" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="42" Height="42" Background="{StaticResource InkBrush}" CornerRadius="8" Margin="0,0,12,0">
                    <TextBlock Text="OW"
                               Foreground="{StaticResource SurfaceBrush}"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel>
                    <TextBlock Text="OpenWith Manager"
                               FontSize="23"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock x:Name="TaglineText"
                               Text="Choose apps for file kinds."
                               Margin="0,3,0,0"
                               Foreground="{StaticResource MutedBrush}" />
                </StackPanel>
            </StackPanel>

            <TextBox x:Name="SearchBox"
                     Grid.Column="1"
                     Width="320"
                     Margin="34,0,16,0"
                     Style="{StaticResource SearchBoxStyle}"
                     HorizontalAlignment="Right"
                     VerticalContentAlignment="Center"
                     TextChanged="OnSearchChanged" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="LanguageButton" Style="{StaticResource IconButton}" Content="中" Click="OnLanguageClicked" />
                <Button x:Name="RefreshButton" Style="{StaticResource IconButton}" Content="Refresh" Click="OnRefreshClicked" />
                <Button x:Name="ExportButton" Style="{StaticResource IconButton}" Content="Export" Click="OnExportClicked" />
                <Button x:Name="CompareButton" Style="{StaticResource IconButton}" Content="Compare" Click="OnImportClicked" />
                <Button x:Name="SettingsButton" Style="{StaticResource PrimaryButton}" Content="Open settings" Click="OnOpenSettingsClicked" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Panel}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,10">
                        <TextBlock x:Name="FileKindsLabel"
                                   Text="File kinds"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="AllFilterButton" Style="{StaticResource PrimaryButton}" Content="All" Click="OnAllFilterClicked" />
                            <Button x:Name="ReviewFilterButton" Style="{StaticResource IconButton}" Content="Needs review" Click="OnReviewFilterClicked" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="EmptyText"
                               DockPanel.Dock="Bottom"
                               Margin="16"
                               Foreground="{StaticResource MutedBrush}"
                               Text="No matching file kinds."
                               Visibility="Collapsed" />

                    <ListBox x:Name="KindList"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="6,0,6,8"
                             SelectionChanged="OnKindSelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,3" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemRoot"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="7">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource HoverBrush}" />
                                                    <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource LineBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource SelectedBrush}" />
                                                    <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#c7c0af" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="58" Margin="10,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" Background="{StaticResource SubtleBrush}" CornerRadius="7">
                                        <TextBlock Text="{Binding ShortName}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource InkBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource InkBrush}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding PrimaryAppName}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Border Grid.Column="2"
                                            Padding="8,4"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Margin="24" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
