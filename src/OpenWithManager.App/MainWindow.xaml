<Window x:Class="OpenWithManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenWith Manager"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#f6f4ee"
        FontFamily="Segoe UI Variable Text, Segoe UI">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="42" Height="42" Background="{StaticResource InkBrush}" CornerRadius="8" Margin="0,0,12,0">
                    <TextBlock Text="OW"
                               Foreground="{StaticResource SurfaceBrush}"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel>
                    <TextBlock Text="OpenWith Manager"
                               FontSize="23"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock x:Name="TaglineText"
                               Text="Choose apps for file kinds."
                               Margin="0,3,0,0"
                               Foreground="{StaticResource MutedBrush}" />
                </StackPanel>
            </StackPanel>

            <TextBox x:Name="SearchBox"
                     Grid.Column="1"
                     Width="320"
                     Margin="34,0,16,0"
                     Style="{StaticResource SearchBoxStyle}"
                     HorizontalAlignment="Right"
                     VerticalContentAlignment="Center"
                     TextChanged="OnSearchChanged" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="LanguageButton" Style="{StaticResource IconButton}" Content="中" Click="OnLanguageClicked" />
                <Button x:Name="RefreshButton" Style="{StaticResource IconButton}" Content="Refresh" Click="OnRefreshClicked" />
                <Button x:Name="PreferencesButton" Style="{StaticResource IconButton}" Content="Preferences" Click="OnPreferencesClicked" />
                <Button x:Name="SettingsButton" Style="{StaticResource PrimaryButton}" Content="Open settings" Click="OnOpenSettingsClicked" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Panel}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,10">
                        <TextBlock x:Name="FileKindsLabel"
                                   Text="File kinds"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="AllFilterButton" Style="{StaticResource PrimaryButton}" Content="All" Click="OnAllFilterClicked" />
                            <Button x:Name="ReviewFilterButton" Style="{StaticResource IconButton}" Content="Needs review" Click="OnReviewFilterClicked" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="EmptyText"
                               DockPanel.Dock="Bottom"
                               Margin="16"
                               Foreground="{StaticResource MutedBrush}"
                               Text="No matching file kinds."
                               Visibility="Collapsed" />

                    <ListBox x:Name="KindList"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="6,0,6,8"
                             SelectionChanged="OnKindSelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,3" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemRoot"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="7">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource HoverBrush}" />
                                                    <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{StaticResource LineBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource SelectedBrush}" />
                                                    <Setter TargetName="ItemRoot" Property="BorderBrush" Value="#c7c0af" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="58" Margin="10,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource InkBrush}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SummaryText}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <ItemsControl Grid.Column="1"
                                                  ItemsSource="{Binding Badges}"
                                                  Margin="12,0,0,0"
                                                  VerticalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="26"
                                                        Height="26"
                                                        Margin="4,0,0,0"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        BorderBrush="{StaticResource LineBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        ToolTip="{Binding Label}">
                                                    <Grid>
                                                        <Image x:Name="BadgeIcon"
                                                               Source="{Binding Icon}"
                                                               Width="18"
                                                               Height="18"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                        <Grid x:Name="BadgePlaceholder"
                                                              Width="13"
                                                              Height="13"
                                                              Visibility="Collapsed"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition />
                                                                <RowDefinition />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition />
                                                                <ColumnDefinition />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Margin="1.3" Background="{StaticResource MutedBrush}" CornerRadius="1.3" />
                                                            <Border Grid.Column="1" Margin="1.3" Background="{StaticResource MutedBrush}" CornerRadius="1.3" />
                                                            <Border Grid.Row="1" Margin="1.3" Background="{StaticResource MutedBrush}" CornerRadius="1.3" />
                                                            <Border Grid.Row="1" Grid.Column="1" Margin="1.3" Background="{StaticResource MutedBrush}" CornerRadius="1.3" />
                                                        </Grid>
                                                        <TextBlock x:Name="BadgeInitial"
                                                                   Text="{Binding Initial}"
                                                                   Visibility="Collapsed"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                        <Setter TargetName="BadgeIcon" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="BadgePlaceholder" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsOverflow}" Value="True">
                                                        <Setter TargetName="BadgePlaceholder" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="BadgeInitial" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="DetailHeaderPanel"
                                Margin="24,24,24,14" />

                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid Margin="24,18,24,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="0.85*" />
                            </Grid.ColumnDefinitions>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="DetailPanel" />
                            </ScrollViewer>

                            <Border Grid.Column="2"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1,0,0,0"
                                    Padding="18,0,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="FormatWorkPanel" />
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="ToastBorder"
                Grid.RowSpan="3"
                Panel.ZIndex="30"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                MaxWidth="420"
                Margin="0,0,0,4"
                Padding="14,12"
                Background="{StaticResource InkBrush}"
                BorderBrush="#3a3d34"
                BorderThickness="1"
                CornerRadius="7">
            <TextBlock x:Name="ToastText"
                       Foreground="{StaticResource SurfaceBrush}"
                       TextWrapping="Wrap" />
        </Border>

        <Grid x:Name="PreferencesOverlay"
              Grid.RowSpan="3"
              Panel.ZIndex="20"
              Visibility="Collapsed">
            <Border Background="#66000000"
                    MouseDown="OnPreferencesOverlayMouseDown" />
            <Border x:Name="PreferencesPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="460"
                    MaxHeight="600"
                    Padding="22"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="PreferencesTitle"
                                       Text="Preferences"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}" />
                            <TextBlock x:Name="PreferencesSubtitle"
                                       Text="Display and behavior options."
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="ClosePreferencesButton"
                                Grid.Column="1"
                                Style="{StaticResource IconButton}"
                                Content="Close"
                                Click="OnClosePreferencesClicked" />
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock x:Name="PreferencesDisplayLabel"
                                       Text="Display"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,0,10" />
                            <Button x:Name="SettingsLanguageButton"
                                    Style="{StaticResource IconButton}"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,0,0,10"
                                    Click="OnSettingsLanguageClicked" />
                            <CheckBox x:Name="DeveloperViewCheckBox"
                                      Margin="0,0,0,10"
                                      Click="OnDeveloperViewClicked" />
                            <CheckBox x:Name="ShowTechnicalDetailsCheckBox"
                                      Margin="0,0,0,10"
                                      Click="OnShowTechnicalDetailsClicked" />
                            <CheckBox x:Name="CandidateSourcesCheckBox"
                                      Margin="0,0,0,22"
                                      Click="OnCandidateSourcesClicked" />

                            <TextBlock x:Name="PreferencesBehaviorLabel"
                                       Text="Behavior"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,0,10" />
                            <CheckBox x:Name="AutoRefreshCheckBox"
                                      Margin="0,0,0,22"
                                      Click="OnAutoRefreshClicked" />

                            <TextBlock x:Name="PreferencesSafetyLabel"
                                       Text="Safety"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedBrush}"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="PreferencesSafetyText"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
