<Window x:Class="OpenWithManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenWith Manager"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#f5f3ee">
    <Window.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#d8d5cc" />
            <Setter Property="Background" Value="#fffefa" />
            <Setter Property="Foreground" Value="#252721" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Background" Value="#252721" />
            <Setter Property="Foreground" Value="#fffefa" />
            <Setter Property="BorderBrush" Value="#252721" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="#fffefa" />
            <Setter Property="BorderBrush" Value="#dedbd3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="42" Height="42" Background="#252721" CornerRadius="6" Margin="0,0,12,0">
                    <TextBlock Text="OW"
                               Foreground="#fffefa"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel>
                    <TextBlock Text="OpenWith Manager"
                               FontSize="23"
                               FontWeight="SemiBold"
                               Foreground="#252721" />
                    <TextBlock x:Name="TaglineText"
                               Text="Choose apps for file kinds."
                               Margin="0,3,0,0"
                               Foreground="#6c6a62" />
                </StackPanel>
            </StackPanel>

            <TextBox x:Name="SearchBox"
                     Grid.Column="1"
                     Width="320"
                     Height="38"
                     Margin="34,0,16,0"
                     Padding="12,8"
                     HorizontalAlignment="Right"
                     VerticalContentAlignment="Center"
                     BorderBrush="#d8d5cc"
                     Background="#fffefa"
                     TextChanged="OnSearchChanged" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="LanguageButton" Style="{StaticResource IconButton}" Content="中" Click="OnLanguageClicked" />
                <Button x:Name="RefreshButton" Style="{StaticResource IconButton}" Content="Refresh" Click="OnRefreshClicked" />
                <Button x:Name="ExportButton" Style="{StaticResource IconButton}" Content="Export" Click="OnExportClicked" />
                <Button x:Name="CompareButton" Style="{StaticResource IconButton}" Content="Compare" Click="OnImportClicked" />
                <Button x:Name="SettingsButton" Style="{StaticResource PrimaryButton}" Content="Open settings" Click="OnOpenSettingsClicked" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Panel}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,10">
                        <TextBlock x:Name="FileKindsLabel"
                                   Text="File kinds"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#7a776f" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="AllFilterButton" Style="{StaticResource PrimaryButton}" Content="All" Click="OnAllFilterClicked" />
                            <Button x:Name="ReviewFilterButton" Style="{StaticResource IconButton}" Content="Needs review" Click="OnReviewFilterClicked" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="EmptyText"
                               DockPanel.Dock="Bottom"
                               Margin="16"
                               Foreground="#7a776f"
                               Text="No matching file kinds."
                               Visibility="Collapsed" />

                    <ListBox x:Name="KindList"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionChanged="OnKindSelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="10,3" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="54" Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" Background="#eeece4" CornerRadius="5">
                                        <TextBlock Text="{Binding ShortName}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#252721"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="#252721"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding PrimaryAppName}"
                                                   Margin="0,4,0,0"
                                                   Foreground="#6c6a62"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Status}"
                                               Foreground="#6c6a62"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Panel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel" Margin="24" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
